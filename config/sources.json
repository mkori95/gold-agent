      "url": "https://api.gold-api.com",
      "type": "api",
      "priority": 1,
      "enabled": true,
      "health_status": "healthy",
      "consecutive_failures": 0,
      "metals": ["gold", "silver", "platinum", "copper"],
      "endpoints": {
        "symbols": "/symbols",
        "price": "/price/{symbol}"
      },
      "auth": {
        "required": false,
        "type": null,
        "env_key": null
      },
      "rate_limit": {
        "requests_per_month": null,
        "is_unlimited": true,
        "current_month_count": 0,
        "strategy": "no_limit"
      },
      "schedule": {
        "frequency_minutes": 60,
        "active_hours_ist": "00:00-23:59",
        "timezone": "Asia/Kolkata"
      },
      "failure_handling": {
        "max_consecutive_failures": 3,
        "retry_delay_minutes": 15,
        "circuit_breaker_reset_minutes": 60,
        "fallback_source": "metals_dev"
      },
      "fields_map": {
        "price": "price",
        "symbol": "symbol",
        "name": "name",
        "timestamp": "updatedAt"
      },
      "notes": "Primary live price source — unlimited, no auth needed. Covers all 4 metals."
    },
    {
      "id": "metals_dev",
      "name": "Metals.Dev",
      "url": "https://api.metals.dev/v1",
      "type": "api",
      "priority": 1,
      "enabled": true,
      "health_status": "healthy",
      "consecutive_failures": 0,
      "metals": ["gold", "silver", "platinum", "copper"],
      "endpoints": {
        "latest": "/latest?api_key={api_key}&currency=USD&unit=toz"
      },
      "auth": {
        "required": true,
        "type": "query_param",
        "env_key": "METALS_DEV_API_KEY"
      },
      "rate_limit": {
        "requests_per_month": 100,
        "is_unlimited": false,
        "current_month_count": 0,
        "strategy": "twice_daily",
        "warning_threshold": 80,
        "critical_threshold": 95
      },
      "schedule": {
        "frequency_minutes": 720,
        "active_hours_ist": "06:00-22:00",
        "timezone": "Asia/Kolkata"
      },
      "failure_handling": {
        "max_consecutive_failures": 3,
        "retry_delay_minutes": 15,
        "circuit_breaker_reset_minutes": 60,
        "fallback_source": "gold_api_com"
      },
      "fields_map": {
        "gold_usd": "metals.gold",
        "silver_usd": "metals.silver",
        "platinum_usd": "metals.platinum",
        "copper_usd": "metals.copper",
        "mcx_gold": "metals.mcx_gold",
        "mcx_silver": "metals.mcx_silver",
        "ibja_gold": "metals.ibja_gold",
        "inr_rate": "currencies.INR",
        "timestamp": "timestamps.metal"
      },
      "notes": "Most valuable source — gives MCX + IBJA + INR conversion in one call. Run twice daily to stay within 100/month limit."
    },
